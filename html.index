<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Workout Tracker Dark</title>
    <style>
        :root {
            --bg: #121212;
            --card-bg: #1e1e1e;
            --primary: #4ade80; /* 세련된 네온 그린 */
            --text: #e0e0e0;
            --border: #333;
        }
        body { font-family: -apple-system, sans-serif; background: var(--bg); margin: 0; padding: 15px; color: var(--text); }
        .container { max-width: 500px; margin: 0 auto; }
        
        .card { background: var(--card-bg); padding: 20px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); margin-bottom: 20px; border: 1px solid var(--border); }
        h2 { font-size: 1.3rem; margin-top: 0; text-align: center; color: var(--primary); letter-spacing: -0.5px; }

        /* 달력 다크 디자인 */
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; text-align: center; }
        .day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 12px; background: #252525; cursor: pointer; border: 1px solid var(--border); font-size: 0.9rem; transition: 0.3s; }
        .day.today { border: 2px solid var(--primary); color: var(--primary); font-weight: bold; }
        .day.has-workout { background: rgba(74, 222, 128, 0.2); border: 1px solid var(--primary); color: var(--primary); font-weight: bold; }

        /* 모달 다크 디자인 */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); align-items: flex-start; justify-content: center; overflow-y: auto; z-index: 1000; backdrop-filter: blur(5px); }
        .modal-content { background: var(--card-bg); padding: 25px; border-radius: 25px; width: 92%; max-width: 450px; margin: 30px 0; border: 1px solid var(--border); }
        
        .section-label { font-weight: 600; margin: 15px 0 8px; display: block; color: #aaa; font-size: 0.9rem; }
        input, select { background: #2d2d2d; border: 1px solid var(--border); color: white; padding: 14px; border-radius: 12px; font-size: 1rem; box-sizing: border-box; width: 100%; }
        input::placeholder { color: #666; }

        .input-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 10px; }
        
        .record-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 0.85rem; }
        .record-table th { color: #777; border-bottom: 1px solid var(--border); padding: 10px; text-align: left; }
        .record-table td { border-bottom: 1px solid var(--border); padding: 12px 10px; }
        .delete-text { color: #ff5f5f; font-weight: bold; cursor: pointer; }

        .add-btn { width: 100%; padding: 12px; background: transparent; color: var(--primary); border: 1px dashed var(--primary); border-radius: 12px; font-weight: bold; margin: 10px 0; }
        .submit-btn { width: 100%; padding: 18px; background: var(--primary); color: #000; border: none; border-radius: 15px; font-size: 1.1rem; font-weight: 800; margin-top: 25px; }
    </style>
</head>
<body>

<div class="container">
    <div class="card">
        <h2 id="month-display">로딩 중...</h2>
        <div class="calendar-grid" id="calendar-days"></div>
    </div>
</div>

<div id="record-modal" class="modal">
    <div class="modal-content">
        <h3 id="date-title" style="margin-top:0; text-align:center;">WORKOUT LOG</h3>
        
        <label class="section-label">BODY WEIGHT (kg)</label>
        <input type="number" id="weight" step="0.1" placeholder="00.0">

        <hr style="border:0; border-top:1px solid var(--border); margin:25px 0;">

        <label class="section-label">EXERCISE</label>
        <select id="w-name" onchange="toggleEtc(this)">
            <option value="체스트프레스">체스트프레스</option>
            <option value="사이드레터럴레이즈">사이드레터럴레이즈</option>
            <option value="레그프레스">레그프레스</option>
            <option value="삼두">삼두</option>
            <option value="이두">이두</option>
            <option value="덤벨이두">덤벨이두</option>
            <option value="기타">기타(직접입력)</option>
        </select>
        <input type="text" id="w-etc" placeholder="운동 이름 입력" style="margin-top:10px; display:none;">
        
        <div class="input-row" style="margin-top:10px;">
            <input type="number" id="w-weight" placeholder="kg">
            <input type="number" id="w-reps" placeholder="회">
            <input type="number" id="w-sets" placeholder="set">
        </div>
        <button class="add-btn" onclick="addRecordToList()">+ ADD TO LIST</button>

        <table class="record-table">
            <thead>
                <tr><th>운동명</th><th>상세</th><th>삭제</th></tr>
            </thead>
            <tbody id="record-body"></tbody>
        </table>

        <button class="submit-btn" onclick="saveToSheet()">SAVE DATA</button>
        <button onclick="closeModal()" style="width:100%; margin-top:20px; background:none; border:none; color:#555;">CLOSE</button>
    </div>
</div>

<script>
    const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxzCpvTDYUoSCig32Atx87mF8P7730i4Wx_tZF4Ixuo5p65zu8Bqsa_tC42okRVcmWDJQ/exec'; 
    let selectedDate = '';
    let currentWorkouts = [];
    let recordedDates = []; // 운동 기록이 있는 날짜들

    // 페이지 로드 시 기존 기록 가져오기
    async function loadRecords() {
        try {
            const response = await fetch(SCRIPT_URL);
            const data = await response.json();
            // 'O'인 날짜만 추출하여 배열에 저장
            recordedDates = data.filter(item => item.done === 'O').map(item => item.date);
            initCalendar();
        } catch (e) {
            console.log("기록 로드 실패", e);
            initCalendar();
        }
    }

    function initCalendar() {
        const now = new Date();
        const year = now.getFullYear();
        const month = now.getMonth();
        document.getElementById('month-display').innerText = `${year}년 ${month + 1}월`;
        const grid = document.getElementById('calendar-days');
        grid.innerHTML = '';
        
        ['S','M','T','W','T','F','S'].forEach(w => {
            const el = document.createElement('div'); el.innerText = w; el.style.color="#555"; el.style.fontSize="0.7rem"; grid.appendChild(el);
        });

        const firstDay = new Date(year, month, 1).getDay();
        const lastDate = new Date(year, month + 1, 0).getDate();
        for(let i=0; i<firstDay; i++) grid.appendChild(document.createElement('div'));

        for(let i=1; i<=lastDate; i++) {
            const dayEl = document.createElement('div');
            dayEl.className = 'day';
            const dateStr = `${year}-${month + 1}-${i}`;
            
            if(i === now.getDate()) dayEl.classList.add('today');
            // 기록이 있는 날짜라면 클래스 추가
            if(recordedDates.includes(dateStr)) dayEl.classList.add('has-workout');
            
            dayEl.innerText = i;
            dayEl.onclick = () => openModal(year, month + 1, i);
            grid.appendChild(dayEl);
        }
    }

    function openModal(y, m, d) {
        selectedDate = `${y}-${m}-${d}`;
        document.getElementById('date-title').innerText = `${m}월 ${d}일`;
        currentWorkouts = [];
        updateTable();
        document.getElementById('record-modal').style.display = 'flex';
    }

    function closeModal() { document.getElementById('record-modal').style.display = 'none'; }
    function toggleEtc(sel) { document.getElementById('w-etc').style.display = (sel.value === '기타') ? 'block' : 'none'; }

    function addRecordToList() {
        let name = document.getElementById('w-name').value;
        if(name === '기타') name = document.getElementById('w-etc').value;
        const weight = document.getElementById('w-weight').value;
        const reps = document.getElementById('w-reps').value;
        const sets = document.getElementById('w-sets').value;
        if(!name || !reps || !sets) return alert("운동 상세를 입력하세요.");
        currentWorkouts.push({ name, weight: weight || 0, reps, sets });
        document.getElementById('w-weight').value = ''; document.getElementById('w-reps').value = ''; document.getElementById('w-sets').value = '';
        updateTable();
    }

    function updateTable() {
        const tbody = document.getElementById('record-body');
        tbody.innerHTML = '';
        currentWorkouts.forEach((item, index) => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td>${item.name}</td><td>${item.weight}kg/${item.reps}회/${item.sets}세트</td><td><span class="delete-text" onclick="removeItem(${index})">X</span></td>`;
            tbody.appendChild(tr);
        });
    }

    function removeItem(index) { currentWorkouts.splice(index, 1); updateTable(); }

    async function saveToSheet() {
        const weight = document.getElementById('weight').value;
        const workoutString = currentWorkouts.map(w => `${w.name}(${w.weight}kg/${w.reps}회/${w.sets}세트)`).join(', ');
        const payload = { date: selectedDate, weight: weight, workoutType: workoutString, workoutDone: currentWorkouts.length > 0 ? 'O' : 'X' };
        
        const btn = document.querySelector('.submit-btn');
        btn.innerText = "SAVING..."; btn.disabled = true;

        try {
            await fetch(SCRIPT_URL, { method: 'POST', body: JSON.stringify(payload) });
            alert('저장 완료!');
            location.reload(); // 저장 후 새로고침하여 달력 색상 반영
        } catch (e) {
            alert('오류 발생');
            btn.disabled = false;
        }
    }

    loadRecords(); // 시작 시 데이터 로드
</script>
</body>
</html>
